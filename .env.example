# Server IP - change this to your actual LAN IP (e.g., 192.168.1.42)
SERVER_IP=192.168.1.42

# Homepage allowed hosts (comma-separated)
HOMEPAGE_ALLOWED_HOSTS=${SERVER_IP}:3000,localhost:3000,127.0.0.1:3000

# Timezone
TZ=Europe/Bratislava

# Linux user IDs (only used on Linux production; run `id` and paste values)
PUID=1000
PGID=1000
